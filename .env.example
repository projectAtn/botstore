# BotStore runtime environment example
DATABASE_URL=postgresql+psycopg://botstore:botstore-dev-password@db:5432/botstore
BOTSTORE_BOT_KEY=
WORKER_MODE=queue_consumer
WORKER_INTERVAL_SECONDS=30
WORKER_RUN_IMMEDIATELY=true
JOB_QUEUE_PATH=/app/research/job-queue.jsonl
JOB_STATUS_PATH=/app/research/job-status.json
ARTIFACTS_DIR=/app/research/artifacts
